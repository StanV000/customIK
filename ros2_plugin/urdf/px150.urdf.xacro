<?xml version="1.0"?>
<robot name="px150" xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:arg name="robot_name" default="px150"/>
  <xacro:arg name="use_world_frame" default="false"/>

  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>

  <xacro:if value="$(arg use_world_frame)">
    <link name="world"/>
    <joint name="world_to_base" type="fixed">
      <parent link="world"/>
      <child link="base_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>
  </xacro:if>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.0325" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.065"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.0325" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.065"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.0325" rpy="0 0 0"/>
      <mass value="0.8"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <link name="shoulder_link">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.08 0.06"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.08 0.06"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <mass value="0.3"/>
      <inertia ixx="0.0005" iyy="0.0005" izz="0.0005" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="waist" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.065" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="8.0" velocity="3.14159"/>
  </joint>

  <link name="upper_arm_link">
    <visual>
      <origin xyz="0.03 0 0.08" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.05 0.16"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0.03 0 0.08" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.05 0.16"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.03 0 0.08" rpy="0 0 0"/>
      <mass value="0.35"/>
      <inertia ixx="0.0007" iyy="0.0007" izz="0.0007" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="shoulder" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.97222" upper="1.93733" effort="18.0" velocity="3.14159"/>
  </joint>

  <link name="forearm_link">
    <visual>
      <origin xyz="0.025 0 0.08" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.04 0.16"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0.025 0 0.08" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.04 0.16"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.025 0 0.08" rpy="0 0 0"/>
      <mass value="0.25"/>
      <inertia ixx="0.0005" iyy="0.0005" izz="0.0005" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="elbow" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0.06 0 0.16" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0944" upper="1.65806" effort="13.0" velocity="3.14159"/>
  </joint>

  <link name="wrist_link">
    <visual>
      <origin xyz="0.02 0 0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.04"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0.02 0 0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.02 0 0.02" rpy="0 0 0"/>
      <mass value="0.09"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="wrist_angle" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_link"/>
    <origin xyz="0.05 0 0.16" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.74533" upper="2.14675" effort="5.0" velocity="3.14159"/>
  </joint>

  <link name="gripper_link">
    <visual>
      <origin xyz="0.03 0 0.0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.03 0.02"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0.03 0 0.0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.03 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.03 0 0.0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00005" iyy="0.00005" izz="0.00005" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="wrist_rotate" type="revolute">
    <parent link="wrist_link"/>
    <child link="gripper_link"/>
    <origin xyz="0.04 0 0.0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="1.0" velocity="3.14159"/>
  </joint>

  <link name="ee_link">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="ee_fixed" type="fixed">
    <parent link="gripper_link"/>
    <child link="ee_link"/>
    <origin xyz="0.06 0 0" rpy="0 0 0"/>
  </joint>

</robot>
